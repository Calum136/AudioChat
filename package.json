{
  "name": "sidequest",
  "private": true,
  "version": "0.4.9",
  "description": "Cozy multiplayer rooms with voice chat",
  "author": "Calum",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"node server/server.js\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder",
    "electron:preview": "electron ."
  },
  "build": {
    "appId": "com.sidequest.app",
    "productName": "Sidequest",
    "directories": {
      "output": "release-v3"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/icon.ico",
      "signAndEditExecutable": false,
      "legalTrademarks": "Calum Kershaw"
    },
    "mac": {
      "target": "dmg",
      "icon": "electron/icon.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "installerIcon": "electron/icon.ico",
      "uninstallerIcon": "electron/icon.ico"
    },
    "publish": {
      "provider": "github",
      "owner": "Calum136",
      "repo": "AudioChat",
      "private": true
    }
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.99.2",
    "dotenv": "^17.3.1",
    "electron-updater": "^6.8.3",
    "express": "^5.2.1",
    "livekit-client": "^2.17.3",
    "livekit-server-sdk": "^2.15.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.19.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.1.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  }
}
